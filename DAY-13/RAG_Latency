import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.metrics.pairwise import cosine_similarity

evaluation_queries = [
    (
        "Describe the concept of Retrieval-Augmented Generation.",
        "Retrieval-Augmented Generation"
    ),
    (
        "Explain the working mechanism of FAISS.",
        "FAISS"
    ),
    (
        "Give an overview of the BM25 ranking algorithm.",
        "BM25"
    ),
    (
        "Describe the architecture of Transformer models.",
        "Transformer"
    ),
    (
        "How is DNA modified using CRISPR technology?",
        "CRISPR"
    ),
    (
        "Explain the major factors responsible for climate change.",
        "Climate Change"
    ),
    (
        "How does hybrid search improve information retrieval?",
        "Azure AI Search"
    ),
    (
        "What are text embeddings and why are they important?",
        "Embeddings"
    )
]

evaluation_results = []

for user_query, expected_doc in evaluation_queries:

    retrieved_docs = azure_hybrid_search(
        user_query,
        top_k=5
    )

    matched_docs = sum(
        1
        for item in retrieved_docs
        if expected_doc.lower() in item["title"].lower()
    )

    context_score = matched_docs / len(retrieved_docs)

    response_data = rag_answer(user_query)

    generated_text = response_data.answer

    query_embedding = embeddings.embed_query(user_query)

    response_embedding = embeddings.embed_query(
        generated_text
    )

    similarity_score = cosine_similarity(
        [query_embedding],
        [response_embedding]
    )[0][0]

    estimated_tokens = (
        len(user_query.split()) +
        len(generated_text.split())
    ) * 1.3

    evaluation_results.append({
        "Question": user_query,
        "ContextScore": round(context_score, 3),
        "RelevanceScore": round(
            float(similarity_score),
            3
        ),
        "TokenCount": int(estimated_tokens),
        "EmbeddingTime": round(
            response_data.embed_ms,
            2
        ),
        "RetrievalTime": round(
            response_data.retrieve_ms,
            2
        ),
        "GenerationTime": round(
            response_data.generate_ms,
            2
        ),
        "EndToEndLatency": round(
            response_data.total_ms,
            2
        )
    })

results_table = pd.DataFrame(
    evaluation_results
)

print("\nQUERY LEVEL RESULTS")
print(results_table.to_string(index=False))

mean_context_score = results_table[
    "ContextScore"
].mean()

mean_relevance_score = results_table[
    "RelevanceScore"
].mean()

mean_token_count = results_table[
    "TokenCount"
].mean()

mean_latency = results_table[
    "EndToEndLatency"
].mean()

latency_p95 = np.percentile(
    results_table["EndToEndLatency"],
    95
)

latency_std = results_table[
    "EndToEndLatency"
].std()

latency_cv = (
    latency_std /
    mean_latency
) * 100

metrics_summary = pd.DataFrame({
    "Metric": [
        "Mean Context Score",
        "Mean Relevance Score",
        "Average Tokens",
        "Average Latency (ms)",
        "95th Percentile Latency",
        "Latency Standard Deviation",
        "Latency Coefficient of Variation"
    ],
    "Value": [
        round(mean_context_score, 3),
        round(mean_relevance_score, 3),
        round(mean_token_count, 0),
        round(mean_latency, 2),
        round(latency_p95, 2),
        round(latency_std, 2),
        round(latency_cv, 2)
    ]
})
print("\nOVERALL METRICS")
print(metrics_summary.to_string(index=False))
plt.figure(figsize=(10, 5))
plt.plot(
    range(1, len(results_table) + 1),
    results_table["EndToEndLatency"],
    marker="o"
)
plt.xticks(
    range(1, len(results_table) + 1),
    [
        f"Query-{i}"
        for i in range(1, 9)
    ]
)
plt.xlabel("Evaluation Queries")
plt.ylabel("Latency (ms)")
plt.title("RAG Query Latency Analysis")
plt.grid(True)

plt.show()