## 5. Integrated Automation Workflow

```python
import schedule
import subprocess
import time

def workflow_task():

    print(
        "Running automation workflow..."
    )

    process = subprocess.run(
        "echo Task Completed Successfully",
        capture_output=True,
        text=True,
        shell=True
    )

    print(process.stdout)

schedule.every(3).seconds.do(
    workflow_task
)

for _ in range(5):
    schedule.run_pending()
    time.sleep(3)

