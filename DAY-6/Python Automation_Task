import argparse

parser = argparse.ArgumentParser(
    description="User Greeting Utility"
)

parser.add_argument(
    "--name",
    type=str,
    help="User Name"
)

parser.add_argument(
    "--city",
    type=str,
    help="City Name"
)

args = parser.parse_args(
    args=["--name", "Indhu"]
)

print(f"Hello {args.name}")
