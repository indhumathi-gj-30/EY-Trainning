routers/purchases.py — Purchase Endpoints
=========
Complete CRUD + status update + analytics extension.


from typing import List, Literal, Optional
from uuid import UUID

from fastapi import APIRouter, Depends, HTTPException, Query, status

from app.database import PurchaseRepository, get_repository
from app.models import (
    Purchase,
    PurchaseCreate,
    PurchaseResponse,
    PurchaseStatus,
)

router = APIRouter(prefix="/purchases", tags=["Purchases"])


# ── CREATE PURCHASE ─

@router.post(
    "/",
    response_model=PurchaseResponse,
    status_code=status.HTTP_201_CREATED,
    summary="Create a new purchase",
)
def create_purchase(
    payload: PurchaseCreate,
    repo: PurchaseRepository = Depends(get_repository),
) -> PurchaseResponse:
    """
    Accepts a nested PurchaseCreate request:

    - customer details
    - purchased items
    - payment information
    - optional remarks

    Returns a PurchaseResponse with an
    additional analytics summary section.
    """
    purchase = Purchase(**payload.model_dump())
    saved_purchase = repo.save(purchase)
    return PurchaseResponse.from_purchase(saved_purchase)


# ── FETCH ALL PURCHASES ─

@router.get(
    "/",
    response_model=List[PurchaseResponse],
    summary="List all purchases",
)
def list_purchases(
    status_filter: Optional[PurchaseStatus] = Query(
        default=None,
        alias="status",
        description="Filter purchases by current status",
    ),
    skip: int = Query(
        default=0,
        ge=0,
        description="Records to skip",
    ),
    limit: int = Query(
        default=10,
        ge=1,
        le=100,
        description="Maximum records to return",
    ),
    sort_by: Literal["created_at", "grand_total"] = Query(
        default="created_at",
        description="Sort by created date or grand total",
    ),
    repo: PurchaseRepository = Depends(get_repository),
) -> List[PurchaseResponse]:

    purchases = repo.list_all()

    if status_filter is not None:
        purchases = [
            purchase
            for purchase in purchases
            if purchase.status == status_filter
        ]

    responses = [
        PurchaseResponse.from_purchase(purchase)
        for purchase in purchases
    ]

    if sort_by == "grand_total":
        responses.sort(
            key=lambda response: response.summary.grand_total,
            reverse=True,
        )
    else:
        responses.sort(
            key=lambda response: response.created_at,
            reverse=True,
        )

    return responses[skip : skip + limit]


# ── FETCH SINGLE PURCHASE ─

@router.get(
    "/{purchase_id}",
    response_model=PurchaseResponse,
    summary="Get purchase by ID",
)
def get_purchase(
    purchase_id: UUID,
    repo: PurchaseRepository = Depends(get_repository),
) -> PurchaseResponse:

    purchase = repo.get(purchase_id)

    if not purchase:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Purchase {purchase_id} not found.",
        )

    return PurchaseResponse.from_purchase(purchase)


# ── UPDATE PURCHASE STATUS ─

@router.patch(
    "/{purchase_id}/status",
    response_model=PurchaseResponse,
    summary="Update purchase status",
)
def update_purchase_status(
    purchase_id: UUID,
    new_status: PurchaseStatus,
    repo: PurchaseRepository = Depends(get_repository),
) -> PurchaseResponse:
    """
    Updates only the purchase status
    without modifying other fields.
    """

    purchase = repo.update_status(
        purchase_id,
        new_status,
    )

    if not purchase:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Purchase {purchase_id} not found.",
        )

    return PurchaseResponse.from_purchase(purchase)


# ── REMOVE PURCHASE ──

@router.delete(
    "/{purchase_id}",
    status_code=status.HTTP_204_NO_CONTENT,
    summary="Remove a purchase",
)
def delete_purchase(
    purchase_id: UUID,
    repo: PurchaseRepository = Depends(get_repository),
) -> None:

    if not repo.delete(purchase_id):
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Purchase {purchase_id} not found.",
        )